NODE_ENV=development
PORT=3001

# --- Base de datos (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=auth_user
DB_PASSWORD=secret
DB_NAME=auth_db

# --- JWT (RS256) ---
# Por defecto las claves se LEEN DE ARCHIVOS (ver *_PATH).
# Para inyectarlas como variable (producción/SOPS), define JWT_PRIVATE_KEY /
# JWT_PUBLIC_KEY con el PEM inline (saltos como \n): tienen prioridad sobre los archivos.
# Generar el par de claves:
#   openssl genpkey -algorithm RSA -out certs/private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in certs/private.pem -out certs/public.pem
JWT_PRIVATE_KEY_PATH=certs/private.pem
JWT_PUBLIC_KEY_PATH=certs/public.pem
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=auth-service
JWT_AUDIENCE=crm-api

# --- Google Sign-In ---
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
