{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Servicio de autenticación del ecosistema CRM (Node + TypeScript + Hono + MySQL).",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "seed:org": "tsx src/infrastructure/cli/seed-org.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.4.1",
    "amqplib": "^2.0.1",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "google-auth-library": "^9.15.0",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "mysql2": "^3.11.5",
    "sequelize": "^6.37.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "sequelize-cli": "^6.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "type": "commonjs"
}
